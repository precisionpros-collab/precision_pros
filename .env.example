# ============================================
# Precision Pro's — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

AUTH_SECRET=your_auth_secret_here
ADMIN_EMAIL=admin@precisionpros.in
ADMIN_PASSWORD=your_secure_password_here

# For local development set this to http://localhost:3000
# For production set this to your HTTPS origin, e.g. https://www.precisionpros.in
NEXTAUTH_URL=http://localhost:3000

REVALIDATE_SECRET=your_revalidate_secret_here

# After first deploy, run supabase-schema-complete.sql in Supabase SQL Editor
